[Desktop Entry]
Name=Wezmux
Comment=Workspace-aware terminal for multi-agent workflows
Keywords=shell;prompt;command;commandline;cmd;
Icon=org.wezmux.wezmux
StartupWMClass=org.wezmux.wezmux
TryExec=wezterm
Exec=wezterm start --cwd .
Type=Application
Categories=System;TerminalEmulator;Utility;
Terminal=false
